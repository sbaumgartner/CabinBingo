# Copy to .env for local dev (`cp .env.example .env`).
# Cognito issuer (JWT authority), not the hosted UI hostname.
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_REDIRECT_URI=http://localhost:5173/callback
VITE_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/
VITE_API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com
